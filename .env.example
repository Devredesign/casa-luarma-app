# Frontend (Create React App)
# Copiá este archivo a `.env.local` y completá los valores.

# URL base del backend (SIN /api al final). Ej:
# - Local: http://localhost:5000
# - Render: https://tu-backend.onrender.com
REACT_APP_API_BASE_URL=

# (Opcional) Google OAuth Client ID si lo querés sacar del código.
REACT_APP_GOOGLE_CLIENT_ID=

# (Opcional) Calendario embebido (solo vista).
# Pegá aquí el URL que viene dentro del iframe "src" en Google Calendar.
REACT_APP_CALENDAR_EMBED_URL=

# (Opcional) Link para abrir el calendario en una pestaña.
REACT_APP_CALENDAR_OPEN_URL=
